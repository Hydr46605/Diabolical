{
  "model": {
    "type": "minecraft:select",
    "property": "minecraft:custom_model_data",
    "index": 0,
    "cases": [
      {
        "when": "diabolical:sinners_effigy",
        "model": {
          "type": "minecraft:model",
          "model": "diabolical:item/sinners_effigy"
        }
      }
    ],
    "fallback": {
      "type": "minecraft:model",
      "model": "minecraft:item/armor_stand"
    }
  },
  "__smithed__": {
    "rules": [
      {
        "type": "smithed:replace",
        "target": "model",
        "source": {
          "type": "smithed:reference",
          "path": "model"
        }
      }
    ]
  }
}
