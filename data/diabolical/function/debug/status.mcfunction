# Prints the current Diabolical debug status for the executing player/admin.
tellraw @s [{"text":"Diabolical","color":"dark_red","bold":true},{"text":" status","color":"gray","bold":false}]
tellraw @s [{"text":"Version: ","color":"gray"},{"nbt":"version","storage":"diabolical:config","color":"white"}]
tellraw @s [{"text":"Runtime: ","color":"gray"},{"nbt":"version","storage":"diabolical:runtime","color":"white"},{"text":" phase ","color":"gray"},{"nbt":"phase","storage":"diabolical:runtime","color":"white"}]
tellraw @s [{"text":"Sin: ","color":"gray"},{"score":{"name":"@s","objective":"diab.sin"},"color":"white"},{"text":"  Debt: ","color":"gray"},{"score":{"name":"@s","objective":"diab.debt"},"color":"white"},{"text":"  Cooldown: ","color":"gray"},{"score":{"name":"@s","objective":"diab.cooldown"},"color":"white"}]
tellraw @s [{"text":"Relic charges: ","color":"gray"},{"score":{"name":"@s","objective":"diab.rcharge"},"color":"white"}]
tellraw @s [{"text":"Contract: ","color":"gray"},{"score":{"name":"@s","objective":"diab.contract"},"color":"white"},{"text":"  Contract debt: ","color":"gray"},{"score":{"name":"@s","objective":"diab.cdebt"},"color":"white"}]
tellraw @s [{"text":"Event active: ","color":"gray"},{"score":{"name":"#event.active","objective":"diab.event"},"color":"white"},{"text":"  Diabolical Night ticks: ","color":"gray"},{"score":{"name":"#diabolical_night","objective":"diab.event"},"color":"white"},{"text":"  Cooldown: ","color":"gray"},{"score":{"name":"#diabolical_night.cooldown","objective":"diab.event"},"color":"white"}]
tellraw @s [{"text":"Event profile: ","color":"gray"},{"score":{"name":"#event.profile","objective":"diab.event"},"color":"white"},{"text":"  Audit cooldown: ","color":"gray"},{"score":{"name":"#audit.cooldown","objective":"diab.event"},"color":"white"},{"text":"  Backlash cooldown: ","color":"gray"},{"score":{"name":"#backlash.cooldown","objective":"diab.event"},"color":"white"}]
tellraw @s [{"text":"Director pressure debt: ","color":"gray"},{"score":{"name":"#director.debt","objective":"diab.event"},"color":"white"},{"text":"  sin: ","color":"gray"},{"score":{"name":"#director.sin","objective":"diab.event"},"color":"white"}]
tellraw @s [{"text":"Collector active: ","color":"gray"},{"score":{"name":"#collector.active","objective":"diab.event"},"color":"white"},{"text":"  Timer: ","color":"gray"},{"score":{"name":"#collector.timer","objective":"diab.event"},"color":"white"},{"text":"  Cooldown: ","color":"gray"},{"score":{"name":"#collector.cooldown","objective":"diab.event"},"color":"white"}]
execute if score @s diab.sin matches 0 run tellraw @s [{"text":"Sin state: ","color":"gray"},{"text":"clean","color":"white"}]
execute if score @s diab.sin matches 1..24 run tellraw @s [{"text":"Sin state: ","color":"gray"},{"text":"marked","color":"yellow"}]
execute if score @s diab.sin matches 25..74 run tellraw @s [{"text":"Sin state: ","color":"gray"},{"text":"stained","color":"gold"}]
execute if score @s diab.sin matches 75..149 run tellraw @s [{"text":"Sin state: ","color":"gray"},{"text":"condemned","color":"red"}]
execute if score @s diab.sin matches 150.. run tellraw @s [{"text":"Sin state: ","color":"gray"},{"text":"infernal","color":"dark_red"}]
execute if score @s diab.debt matches 0 run tellraw @s [{"text":"Debt state: ","color":"gray"},{"text":"clear","color":"white"}]
execute if score @s diab.debt matches 1..9 run tellraw @s [{"text":"Debt state: ","color":"gray"},{"text":"minor","color":"yellow"}]
execute if score @s diab.debt matches 10..49 run tellraw @s [{"text":"Debt state: ","color":"gray"},{"text":"active","color":"gold"}]
execute if score @s diab.debt matches 50..99 run tellraw @s [{"text":"Debt state: ","color":"gray"},{"text":"severe","color":"red"}]
execute if score @s diab.debt matches 100.. run tellraw @s [{"text":"Debt state: ","color":"gray"},{"text":"collector priority","color":"dark_red"}]
execute if entity @s[tag=diab.player] run tellraw @s [{"text":"Initialized: ","color":"gray"},{"text":"yes","color":"green"}]
execute unless entity @s[tag=diab.player] run tellraw @s [{"text":"Initialized: ","color":"gray"},{"text":"no","color":"red"}]
execute if entity @s[tag=diab.contracts_unlocked] run tellraw @s [{"text":"Contracts unlocked: ","color":"gray"},{"text":"yes","color":"green"}]
execute unless entity @s[tag=diab.contracts_unlocked] run tellraw @s [{"text":"Contracts unlocked: ","color":"gray"},{"text":"no","color":"red"}]
execute if entity @s[tag=diab.contract.pact_of_embers] run tellraw @s [{"text":"Active contract: ","color":"gray"},{"text":"Pact of Embers","color":"gold"}]
execute if entity @s[tag=diab.contract.pact_of_hunger] run tellraw @s [{"text":"Active contract: ","color":"gray"},{"text":"Pact of Hunger","color":"gold"}]
execute if entity @s[tag=diab.contract.red_ledger_minor] run tellraw @s [{"text":"Active contract: ","color":"gray"},{"text":"Red Ledger Minor","color":"gold"}]
execute if entity @s[tag=diab.contract.pact_of_copper] run tellraw @s [{"text":"Active contract: ","color":"gray"},{"text":"Pact of Copper","color":"gold"}]
execute if entity @s[tag=diab.contract.greed_clause] run tellraw @s [{"text":"Active contract: ","color":"gray"},{"text":"Greed Clause","color":"gold"}]
execute if entity @s[tag=diab.contract.the_red_ledger] run tellraw @s [{"text":"Active contract: ","color":"gray"},{"text":"The Red Ledger","color":"dark_red"}]
execute unless entity @s[tag=diab.contract_active] run tellraw @s [{"text":"Active contract: ","color":"gray"},{"text":"none","color":"white"}]
execute if entity @s[tag=diab.relic_holder] run tellraw @s [{"text":"Relic selected: ","color":"gray"},{"text":"yes","color":"green"}]
execute unless entity @s[tag=diab.relic_holder] run tellraw @s [{"text":"Relic selected: ","color":"gray"},{"text":"no","color":"white"}]
execute if entity @s[tag=diab.event_target] run tellraw @s [{"text":"Event target: ","color":"gray"},{"text":"yes","color":"red"}]
execute unless entity @s[tag=diab.event_target] run tellraw @s [{"text":"Event target: ","color":"gray"},{"text":"no","color":"white"}]
execute if entity @s[tag=diab.event_forced] run tellraw @s [{"text":"Forced event target: ","color":"gray"},{"text":"yes","color":"red"}]
execute unless entity @s[tag=diab.event_forced] run tellraw @s [{"text":"Forced event target: ","color":"gray"},{"text":"no","color":"white"}]
execute if entity @s[tag=diab.collector_target] run tellraw @s [{"text":"Collector target: ","color":"gray"},{"text":"yes","color":"red"}]
execute unless entity @s[tag=diab.collector_target] run tellraw @s [{"text":"Collector target: ","color":"gray"},{"text":"no","color":"white"}]
tellraw @s [{"text":"Systems: contracts, rituals, relics, events","color":"gray"}]
