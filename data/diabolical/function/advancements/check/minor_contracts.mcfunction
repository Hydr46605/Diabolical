# Grants the minor-contract mastery challenge once all minor contracts were signed.
execute if entity @s[advancements={diabolical:contracts/pact_of_embers=true,diabolical:contracts/pact_of_hunger=true,diabolical:contracts/red_ledger_minor=true,diabolical:contracts/pact_of_copper=true,diabolical:contracts/greed_clause=true}] run advancement grant @s only diabolical:mastery/minor_contracts
execute if entity @s[advancements={diabolical:contracts/pact_of_embers=true,diabolical:contracts/pact_of_hunger=true,diabolical:contracts/red_ledger_minor=true,diabolical:contracts/pact_of_copper=true,diabolical:contracts/greed_clause=true}] run advancement grant @s only diabolical:contracts/major_unlocked
execute if entity @s[advancements={diabolical:contracts/pact_of_embers=true,diabolical:contracts/pact_of_hunger=true,diabolical:contracts/red_ledger_minor=true,diabolical:contracts/pact_of_copper=true,diabolical:contracts/greed_clause=true}] run tag @s add diab.contracts_major_unlocked
