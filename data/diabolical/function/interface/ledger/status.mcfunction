# Shows the Infernal Ledger account status page.
tellraw @s [{"text":"Infernal Ledger","color":"dark_red","bold":true},{"text":" - Account Status","color":"gray","bold":false}]
function diabolical:interface/ledger/nav
tellraw @s [{"text":"Sin: ","color":"gray"},{"score":{"name":"@s","objective":"diab.sin"},"color":"white"},{"text":"  Debt: ","color":"gray"},{"score":{"name":"@s","objective":"diab.debt"},"color":"white"},{"text":"  Cooldown: ","color":"gray"},{"score":{"name":"@s","objective":"diab.cooldown"},"color":"white"}]
tellraw @s [{"text":"Relic charges: ","color":"gray"},{"score":{"name":"@s","objective":"diab.rcharge"},"color":"white"}]
tellraw @s [{"text":"Contract id: ","color":"gray"},{"score":{"name":"@s","objective":"diab.contract"},"color":"white"},{"text":"  Contract debt: ","color":"gray"},{"score":{"name":"@s","objective":"diab.cdebt"},"color":"white"}]
tellraw @s [{"text":"Systems: ","color":"gray"},{"text":"contracts ","color":"dark_gray"},{"score":{"name":"#contracts","objective":"diab.config"},"color":"white"},{"text":" rituals ","color":"dark_gray"},{"score":{"name":"#rituals","objective":"diab.config"},"color":"white"},{"text":" relics ","color":"dark_gray"},{"score":{"name":"#relics","objective":"diab.config"},"color":"white"},{"text":" events ","color":"dark_gray"},{"score":{"name":"#events","objective":"diab.config"},"color":"white"}]
tellraw @s [{"text":"Event profile: ","color":"gray"},{"score":{"name":"#event.profile","objective":"diab.event"},"color":"white"},{"text":"  Audit cooldown: ","color":"gray"},{"score":{"name":"#audit.cooldown","objective":"diab.event"},"color":"white"}]
execute if score @s diab.sin matches 0 run tellraw @s [{"text":"Sin state: ","color":"gray"},{"text":"clean","color":"white"}]
execute if score @s diab.sin matches 1..24 run tellraw @s [{"text":"Sin state: ","color":"gray"},{"text":"marked","color":"yellow"}]
execute if score @s diab.sin matches 25..74 run tellraw @s [{"text":"Sin state: ","color":"gray"},{"text":"stained","color":"gold"}]
execute if score @s diab.sin matches 75..149 run tellraw @s [{"text":"Sin state: ","color":"gray"},{"text":"condemned","color":"red"}]
execute if score @s diab.sin matches 150.. run tellraw @s [{"text":"Sin state: ","color":"gray"},{"text":"infernal","color":"dark_red"}]
execute if score @s diab.debt matches 0 run tellraw @s [{"text":"Debt state: ","color":"gray"},{"text":"clear","color":"white"}]
execute if score @s diab.debt matches 1..9 run tellraw @s [{"text":"Debt state: ","color":"gray"},{"text":"minor","color":"yellow"}]
execute if score @s diab.debt matches 10..49 run tellraw @s [{"text":"Debt state: ","color":"gray"},{"text":"active","color":"gold"}]
execute if score @s diab.debt matches 50..99 run tellraw @s [{"text":"Debt state: ","color":"gray"},{"text":"severe","color":"red"}]
execute if score @s diab.debt matches 100.. run tellraw @s [{"text":"Debt state: ","color":"gray"},{"text":"collector priority","color":"dark_red"}]
execute if entity @s[tag=diab.contract.pact_of_embers] run tellraw @s [{"text":"Active contract: ","color":"gray"},{"text":"Pact of Embers","color":"gold"}]
execute if entity @s[tag=diab.contract.pact_of_hunger] run tellraw @s [{"text":"Active contract: ","color":"gray"},{"text":"Pact of Hunger","color":"gold"}]
execute if entity @s[tag=diab.contract.red_ledger_minor] run tellraw @s [{"text":"Active contract: ","color":"gray"},{"text":"Red Ledger Minor","color":"gold"}]
execute if entity @s[tag=diab.contract.pact_of_copper] run tellraw @s [{"text":"Active contract: ","color":"gray"},{"text":"Pact of Copper","color":"gold"}]
execute if entity @s[tag=diab.contract.greed_clause] run tellraw @s [{"text":"Active contract: ","color":"gray"},{"text":"Greed Clause","color":"gold"}]
execute if entity @s[tag=diab.contract.the_red_ledger] run tellraw @s [{"text":"Active contract: ","color":"gray"},{"text":"The Red Ledger","color":"dark_red"}]
execute unless entity @s[tag=diab.contract_active] run tellraw @s [{"text":"Active contract: ","color":"gray"},{"text":"none","color":"white"}]
execute if score @s diab.debt matches 1.. run tellraw @s [{"text":"Recovery: ","color":"gray"},{"text":"Ashes Paid, Bell of Remission, contract payments, night survival, or collectors.","color":"white"}]
execute if score @s diab.debt matches 50.. run tellraw @s [{"text":"Risk: ","color":"gray"},{"text":"severe debt can dispatch a Debt Collector.","color":"red"}]
execute if entity @s[tag=diab.event_forced] run tellraw @s [{"text":"Risk: ","color":"gray"},{"text":"you are invited into the current Diabolical Night.","color":"red"}]
